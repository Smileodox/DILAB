# Step 2: Scientific Data Visualization Layout
# -------------------------------------------------------------------------
def generate_impact_probability_matrix(scenarios: List[Scenario], assessments: List[Assessment]):
    """
    Constructs a 2D risk assessment coordinate system rendering evaluation matrices.
    Maps dimensional size and opacity thresholds directly to source node confidence scores.
    """
    logger.info("Initializing vector space graphing layers...")
    
    # Establish production canvas profile specifications
    fig, ax = plt.subplots(figsize=(11, 9))
    
    # Standard color palette maps matching corporate analytical design systems
    type_colors = {
        ScenarioType.EVOLUTIONARY: "#2196F3",  # Deep Blue
        ScenarioType.DISRUPTIVE: "#FF5722",    # Safety Orange
        ScenarioType.CAUTIONARY: "#FFC107",    # Amber Yellow
        ScenarioType.WILDCARD: "#9C27B0",      # Amethyst Purple
    }

    for scenario, assessment in zip(scenarios, assessments):
        color = type_colors.get(scenario.type, "#999999")
        
        # Scaling operations mapping confidence to geometry size metrics
        size = (assessment.confidence * 400) + 100
        alpha = 0.35 + (assessment.confidence * 0.55)

        ax.scatter(
            assessment.probability, 
            assessment.impact, 
            s=size, 
            c=color,
            alpha=alpha, 
            edgecolors="black", 
            linewidth=0.75, 
            zorder=5
        )
        
        # Create clear label designations wrapping wide string entries
        display_title = scenario.title if len(scenario.title) <= 32 else f"{scenario.title[:30]}..."
        ax.annotate(
            display_title, 
            (assessment.probability, assessment.impact),
            textcoords="offset points", 
            xytext=(12, 6), 
            fontsize=8.5,
            fontweight="semibold",
            alpha=0.85,
            arrowprops=dict(arrowstyle="->", color="black", lw=0.4, alpha=0.5)
        )

    # Establish chart bounding constraints and coordinate grids
    ax.set_xlim(0, 10.5)
    ax.set_ylim(0, 10.5)
    ax.set_xlabel("Probability Matrix Assessment Tier", fontsize=12, labelpad=10, fontweight="bold")
    ax.set_ylabel("Impact Matrix Assessment Tier", fontsize=12, labelpad=10, fontweight="bold")
    ax.set_title("Scenario Strategic Assessment Matrix — Foresight Synthesis Horizon 2035\n(Bubble Radius Scales Proportionally with Calculated Pipeline Confidence Indices)", fontsize=12, pad=15, fontweight="bold")
    
    # Section matrix divider layouts
    ax.axhline(y=5, color="#7F8C8D", linestyle="--", alpha=0.5, lw=1.2)
    ax.axvline(x=5, color="#7F8C8D", linestyle="--", alpha=0.5, lw=1.2)
    
    # Structural quadrant context annotations
    ax.text(7.75, 9.5, "QUADRANT I\nHIGH PRIORITY / CRITICAL", ha="center", va="center", fontsize=10, color="#C0392B", fontweight="bold", alpha=0.65)
    ax.text(2.25, 9.5, "QUADRANT II\nMONITOR / CONTINGENCY", ha="center", va="center", fontsize=10, color="#D35400", fontweight="bold", alpha=0.65)
    ax.text(7.75, 0.8, "QUADRANT III\nEXPECTED TRAJECTORIES", ha="center", va="center", fontsize=10, color="#27AE60", fontweight="bold", alpha=0.65)
    ax.text(2.25, 0.8, "QUADRANT IV\nLOW RISK OPERATIONAL", ha="center", va="center", fontsize=10, color="#7F8C8D", fontweight="bold", alpha=0.65)
    
    # Compile multi-variable dynamic legend maps
    legend_elements = [
        Line2D([0], [0], marker='o', color='w', markerfacecolor=c, markersize=12, label=f"{t.value.capitalize()} Nodes")
        for t, c in type_colors.items()
    ]
    ax.legend(handles=legend_elements, loc="lower left", frameon=True, facecolor="#F8F9F9", edgecolor="#BDC3C7", fontsize=10)
    
    ax.grid(True, linestyle=":", alpha=0.4, color="#95A5A6")
    
    # Save visual export down to standard output directory
    plot_path = os.path.join(OUTPUT_DIR, "scenario_matrix.png")
    plt.tight_layout()
    plt.savefig(plot_path, dpi=200)
    plt.close()
    logger.info(f"Visual asset generation step closed. Output file locked at {plot_path}")

# -------------------------------------------------------------------------
# Step 3: Comprehensive End-to-End Traceability Mapping Report
# -------------------------------------------------------------------------
def generate_traceability_report(scenarios: List[Scenario], assessments: List[Assessment]):
    """
    Traverses dependency hierarchies from high-level narrative representations,
    through logical assumptions profiles, down to underlying resource inputs.
    """
    logger.info("Assembling traceability audit matrices...")
    
    with open(os.path.join(OUTPUT_DIR, "kb_state.json")) as f:
        kb_state = json.load(f)
        
    with open(os.path.join(OUTPUT_DIR, "merge_state.json")) as f:
        raw_drivers = json.load(f)["unified_drivers"]
        drivers = [TechDriver(**d) for d in raw_drivers]

    driver_by_id = {d.id: d for d in drivers}
    source_by_id = kb_state["sources"]
    chunk_by_id = kb_state["chunks"]

    print("\n" + "=" * 80)
    print("TRACEABILITY REPORT — END-TO-END ASSUMPTIONS & SOURCE LINEAGE")
    print("=" * 80)

    for scenario, assessment in zip(scenarios, assessments):
        print("\n" + "─" * 80)
        print(f"SCENARIO TITLE : {scenario.title}")
        print(f"METADATA PATH  : Type: {scenario.type.value.upper()} | Strategic Impact Evaluation: {assessment.impact:.1f} | Base Trajectory Probability: {assessment.probability:.1f}")
        print("─" * 80)
        print(f"Narrative Excerpt:\n  \"{scenario.narrative[:320]}...\"")
        
        print("\n  LOGICAL ASSUMPTIONS TRACE:")
        for a in scenario.assumptions:
            d = driver_by_id.get(a.driver_id)
            if d:
                print(f"    [+] Assumption Target : {a.description}")
                print(f"        Lineage Component : Identity Map: {d.id} | Originating Pool Cluster: {d.origin.value.upper()} | Confidence Factor: {d.confidence.value.upper()}")
                if d.merge_reasoning:
                    print(f"        Synthesis Logic   : {d.merge_reasoning[:120]}...")

        print("\n  FOUNDATIONAL RESOURCE INPUT MATERIAL PROFILES:")
        seen_sources = set()
        for chunk_id in scenario.source_chunk_ids:
            chunk = chunk_by_id.get(chunk_id)
            if chunk:
                src = source_by_id.get(chunk["source_id"])
                if src and src["id"] not in seen_sources:
                    seen_sources.add(src["id"])
                    print(f"    📄 Core Document Reference: {src['title']}")
                    print(f"       Resource Attributes    : File Type Format: {src['type'].upper()} | Functional Pool Target: {src['pool'].upper()}")
                    if src.get("url"):
                        print(f"       System Location URL    : {src['url']}")

        print("\n  STRATEGIC EVALUATION REASONING METADATA LOG:")
        print(f"    {assessment.reasoning}")
        print()

    # Consolidate complete execution footprint and dump to storage volume
    final_state = {
        "assessments": [a.model_dump(mode="json") for a in assessments],
        "scenarios": [s.model_dump(mode="json") for s in scenarios],
    }
    
    output_payload_path = os.path.join(OUTPUT_DIR, "final_analysis.json")
    with open(output_payload_path, "w") as f:
        json.dump(final_state, f, indent=2)
        
    print("=" * 80)
    print(f"ANALYSIS RECONCILIATION COMPLETE. Core output states compiled to {output_payload_path}")
    print("=" * 80)

# -------------------------------------------------------------------------
# Core Execution Guard
# -------------------------------------------------------------------------
if __name__ == "__main__":
    logger.info("Initializing Module 07 execution loop context parameters...")
    active_scenarios, active_assessments = run_scenario_assessment()
    generate_impact_probability_matrix(active_scenarios, active_assessments)
    generate_traceability_report(active_scenarios, active_assessments)
    logger.info("Module 07 loop finished processing successfully.")
