# -------------------------------------------------------------------------
# Domain Primitive Definitions (Pydantic Data Schemas)
# -------------------------------------------------------------------------
class DriverConfidence(str, Enum):
    HIGH = "high"
    MEDIUM = "medium"
    LOW = "low"

class DriverOrigin(str, Enum):
    TREND = "trend"
    PRODUCT = "product"
    BOTH = "both"

class ScenarioType(str, Enum):
    EVOLUTIONARY = "evolutionary"
    DISRUPTIVE = "disruptive"
    CAUTIONARY = "cautionary"
    WILDCARD = "wildcard"

class TechDriver(pydantic.BaseModel):
    id: str
    title: str
    confidence: DriverConfidence
    origin: DriverOrigin
    merge_reasoning: Optional[str] = None

class ScenarioAssumption(pydantic.BaseModel):
    driver_id: str
    description: str
    state: str  # e.g., "steady_progress", "breakthrough", "stagnation"

class Scenario(pydantic.BaseModel):
    id: str
    title: str
    type: ScenarioType
    perspective: Optional[str] = None
    key_tensions: List[str] = pydantic.Field(default_factory=list)
    assumptions: List[ScenarioAssumption] = pydantic.Field(default_factory=list)
    narrative: str
    source_chunk_ids: List[str] = pydantic.Field(default_factory=list)

class Assessment(pydantic.BaseModel):
    scenario_id: str
    impact: float = pydantic.Field(..., ge=0.0, le=10.0)
    probability: float = pydantic.Field(..., ge=0.0, le=10.0)
    confidence: float = pydantic.Field(..., ge=0.0, le=1.0)
    reasoning: str
    key_risks: str
    early_signals: str
    source_chunk_ids: List[str] = pydantic.Field(default_factory=list)

# -------------------------------------------------------------------------
# Mocking LLM Infrastructure Components For Standalone Compliance
# -------------------------------------------------------------------------
def embed(texts: List[str]) -> List[List[float]]:
    """Generates deterministic mock vector spaces for downstream vector searches."""
    logger.debug(f"Generating vector embedding for batch of size {len(texts)}")
    np.random.seed(42)
    return [np.random.rand(384).tolist() for _ in texts]

