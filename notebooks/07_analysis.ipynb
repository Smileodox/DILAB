# -------------------------------------------------------------------------
# Step 1: Scenario Context Parsing and Analytical Inference Engine
# -------------------------------------------------------------------------
def run_scenario_assessment() -> Tuple[List[Scenario], List[Assessment]]:
    """
    Parses active structural tracking state files, queries vector space definitions,
    and returns parsed, validated evaluation payloads.
    """
    logger.info("Loading environment tracking pipelines...")
    
    with open(os.path.join(OUTPUT_DIR, "scenario_state.json")) as f:
        raw_scenarios = json.load(f)["scenarios"]
        scenarios = [Scenario(**s) for s in raw_scenarios]
        
    with open(os.path.join(OUTPUT_DIR, "merge_state.json")) as f:
        raw_drivers = json.load(f)["unified_drivers"]
        drivers = [TechDriver(**d) for d in raw_drivers]
        
    with open(os.path.join(OUTPUT_DIR, "kb_state.json")) as f:
        kb_state = json.load(f)

    driver_by_id = {d.id: d for d in drivers}
    logger.info(f"System State: Processing assessment over {len(scenarios)} core target scenarios.")

    # Compute numerical confidence approximations derived from technical base nodes
    conf_map = {DriverConfidence.HIGH: 0.9, DriverConfidence.MEDIUM: 0.6, DriverConfidence.LOW: 0.3}
    scenario_confidences = []
    
    for scenario in scenarios:
        driver_confs = []
        for a in scenario.assumptions:
            d = driver_by_id.get(a.driver_id)
            if d:
                driver_confs.append(conf_map.get(d.confidence, 0.5))
        scenario_confidences.append(round(np.mean(driver_confs), 2) if driver_confs else 0.5)

    # Format pipeline configuration blocks for context assembly
    scenarios_block_parts = []
    for i, scenario in enumerate(scenarios):
        assumptions_text = "\n".join([f"  - {a.description}" for a in scenario.assumptions])
        perspective_line = f"\nPerspective: {scenario.perspective}" if scenario.perspective else ""
        tensions_line = f"\nKey tensions: {', '.join(scenario.key_tensions)}" if scenario.key_tensions else ""
        scenarios_block_parts.append(
            f"### Scenario {i}: {scenario.title}\n"
            f"Type: {scenario.type.value}{perspective_line}{tensions_line}\n"
            f"Assumptions:\n{assumptions_text}\n"
            f"Narrative (excerpt): {scenario.narrative[:600]}"
        )
    scenarios_block = "\n\n".join(scenarios_block_parts)

    # Execute Vector Store Validation Context Search
    logger.info("Initializing vector space tracking requests against 'knowledge_base' collection...")
    try:
        # Mock client construction for standalone isolation execution compatibility
        client = chromadb.PersistentClient(path=CHROMA_PERSIST_DIR)
        # Attempt standard collection bindings
        try:
            collection = client.get_collection("knowledge_base")
            combined_query = " ".join([s.title for s in scenarios])
            query_emb = embed([combined_query[:500]])[0]
            rag = collection.query(query_embeddings=[query_emb], n_results=5, include=["documents", "metadatas"])
            rag_text = "\n\n---\n\n".join([
                f"[Chunk ID: {rag['ids'][0][i]}] (Source: {rag['metadatas'][0][i]['source_title']})\n{rag['documents'][0][i]}"
                for i in range(len(rag["ids"][0]))
            ])
        except Exception:
            logger.warning("Active Vector DB Collection context unpopulated. Sourcing fallback local records...")
            rag_text = "\n\n---\n\n".join([
                f"[Chunk ID: {cid}] Text Content: {cdata['text']}" 
                for cid, cdata in kb_state["chunks"].items()
            ])
    except Exception as ex:
        logger.error(f"Vector Database interface issue encountered: {ex}. Switching to native local state fallback.")
        rag_text = "Fallback Core Metadata State Block Data Only."

    # Execute structured pipeline processing prompt execution sequence
    prompt_template = """
    SYSTEM CAPABILITY EVALUATION ASSIGNMENT:
    Analyze the following {n} future spectrum monitoring scenarios.
    
    SCENARIO DESIGN LAYOUTS:
    {scenarios_block}
    
    VALIDATED SOURCE TRACKS:
    {rag_chunks}
    
    Evaluate each item precisely. Return evaluation matrices across Impact [1..10], Probability [1..10].
    """
    
    prompt = prompt_template.format(
        n=len(scenarios),
        scenarios_block=scenarios_block,
        rag_chunks=rag_text
    )
    
    result = safe_chat_json(
        prompt, 
        system="You are a strategic technology analyst at Rohde & Schwarz evaluating future scenarios for spectrum monitoring."
    )

    assessments: List[Assessment] = []
    batch_assessments = result.get("assessments", [])

    print("\n" + "="*80)
    print("SCENARIO INITIAL PROFILES & METRIC EXTRACTION")
    print("="*80)

    for i, scenario in enumerate(scenarios):
        match = next((a for a in batch_assessments if a.get("scenario_index") == i), None)
        if match:
            impact = match.get("impact", 5.0)
            probability = match.get("probability", 5.0)
            reasoning = match.get("reasoning", "Execution fallback fallback profile applied.")
            key_risks = match.get("key_risks", "System structural opacity.")
            early_signals = match.get("early_signals", "Initial pilot evaluation markers unavailable.")
            source_ids = match.get("source_chunk_ids_used", scenario.source_chunk_ids)
        else:
            impact, probability, reasoning, key_risks, early_signals, source_ids = 5.0, 5.0, "No structural map parsed", "Undefined risk vector", "Unmonitored band state", []

        assessment = Assessment(
            scenario_id=scenario.id,
            impact=impact,
            probability=probability,
            confidence=scenario_confidences[i],
            reasoning=reasoning,
            key_risks=key_risks,
            early_signals=early_signals,
            source_chunk_ids=source_ids
        )
        assessments.append(assessment)

        print(f"  [{scenario.type.value.upper():12s}] {scenario.title}")
        print(f"    Metrics   => Impact: {assessment.impact:.1f} | Probability: {assessment.probability:.1f} | Pipeline Confidence: {assessment.confidence:.2f}")
        print(f"    Core Risks=> {key_risks[:90]}...")
        print(f"    Indicators=> {early_signals[:90]}...\n")
        
    return scenarios, assessments

