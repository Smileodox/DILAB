    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "\n",
    "for scenario, assessment in zip(scenarios, assessments):\n",
    "    # Implemented dictionary safety get-fallbacks to prevent runtime enum key crashes\n",
